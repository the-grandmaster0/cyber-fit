# Client Environment Variables (Vite)
# Copy this file to .env and fill in all values before running the client.
# Only VITE_* variables are bundled into the browser — never put secrets here.

# ─── Supabase (public / anon credentials only) ────────────────────────────────
# Project URL from: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=

# Anon / Publishable key (safe to expose — Row Level Security enforces access).
# Found at: Supabase Dashboard → Project Settings → API → anon / public key
VITE_SUPABASE_PUBLISHABLE_KEY=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Client ID from: Google Cloud Console → Credentials → OAuth 2.0 Client IDs
# This is the public client ID — safe to expose in the browser.
VITE_GOOGLE_CLIENT_ID=

# ─── Backend API ──────────────────────────────────────────────────────────────
# Full URL to the deployed Express backend (no trailing slash).
# Example: https://api.your-domain.com
# In development this is unused — Vite's dev proxy rewrites /api to localhost:3001.
VITE_API_BASE_URL=
