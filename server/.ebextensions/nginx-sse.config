files:
  "/etc/nginx/conf.d/proxy.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # Disable proxy buffering globally so Server-Sent Events (SSE)
      # stream through to the client immediately without being batched.
      proxy_buffering off;
      proxy_cache off;

      # Extended timeouts for long-running SSE connections
      # (12-week plan generation can take up to ~5 minutes)
      proxy_read_timeout 600s;
      proxy_send_timeout 600s;
      proxy_connect_timeout 60s;
