# Server Environment Variables
# Copy this file to .env and fill in all values before starting the server.
# NEVER commit .env to version control.

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# The exact origin of the deployed frontend (no trailing slash).
# Example: https://your-app.vercel.app
CLIENT_ORIGIN=

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL from: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=

# Service Role key (SECRET — backend only, never expose to the browser).
# Found at: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# ─── Google Gemini ────────────────────────────────────────────────────────────
# Create at: https://aistudio.google.com/app/apikey
# Backend-only — never put this in client environment variables.
GEMINI_API_KEY=

# Optional: override the default model (gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# ─── Google OAuth (optional – only if using server-side OAuth flows) ──────────
# Obtain from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
